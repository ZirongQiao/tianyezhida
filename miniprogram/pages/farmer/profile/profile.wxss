@import "../farmer-common.wxss";

.profile-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
}

.profile-avatar {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: #e8f5e9;
  overflow: hidden;
}

.profile-avatar-img {
  width: 100%;
  height: 100%;
}

.profile-avatar-text {
  display: block;
  font-size: 32px;
  font-weight: 600;
  color: #4caf50;
  line-height: 80px;
  text-align: center;
}

.profile-avatar-hint {
  margin-top: 8px;
  font-size: 12px;
  color: #4caf50;
}

.profile-form-card {
  padding: 0 16px;
}

.profile-form-row {
  display: flex;
  align-items: center;
  min-height: 52px;
}

.profile-form-row--border {
  border-top: 1px solid #f0f0f0;
}

.profile-label {
  flex-shrink: 0;
  width: 80px;
  font-size: 14px;
  color: #999999;
}

.profile-input {
  flex: 1;
  font-size: 14px;
  color: #333333;
}

.profile-value {
  flex: 1;
  font-size: 14px;
  color: #333333;
  word-break: break-all;
}

.profile-value--address {
  line-height: 1.4;
}

.profile-readonly-block {
  margin: 2px -8px 0;
  padding: 2px 8px 4px;
  background: #f5f5f5;
  border-radius: 8px;
}

.profile-form-row--readonly {
  align-items: flex-start;
  min-height: auto;
  padding: 8px 4px;
  background: transparent;
}

.profile-form-row--readonly .profile-label {
  padding-top: 0;
}

.profile-label--readonly {
  color: #aaaaaa;
}

.profile-value--readonly {
  color: #999999;
}

.profile-address-tip {
  display: block;
  padding: 4px 4px 2px;
  font-size: 13px;
  line-height: 1.45;
  color: #c45c26;
}

.profile-photos-title {
  display: block;
  margin-bottom: 12px;
  font-size: 15px;
  font-weight: 600;
  color: #333333;
}

.profile-photos {
  display: flex;
  justify-content: space-between;
}

.profile-photo-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 90px;
  height: 90px;
  border: 1px dashed #cccccc;
  border-radius: 8px;
  overflow: hidden;
}

.profile-photo-img {
  width: 100%;
  height: 100%;
}

.profile-photo-plus {
  font-size: 32px;
  color: #cccccc;
  line-height: 1;
}
