.claim-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f7f8fa;
  box-sizing: border-box;
}

.claim-body {
  flex: 1;
  padding: 48rpx 40rpx 32rpx;
  box-sizing: border-box;
}

.claim-card {
  padding: 48rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.claim-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.5;
  text-align: center;
}

.claim-input {
  width: 100%;
  height: 88rpx;
  margin-top: 48rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.claim-input--invalid {
  border-color: #ef4444;
}

.claim-error {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #ef4444;
}

.claim-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin-top: 40rpx;
  padding: 0;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
  color: #ffffff;
  background: #2f7df6;
  border: 2rpx solid #2f7df6;
  border-radius: 48rpx;
  box-sizing: border-box;
}

.claim-btn::after {
  border: none;
}

.claim-btn--disabled {
  color: #ffffff;
  background: #94b8f7;
  border-color: #94b8f7;
}

.claim-tip {
  display: block;
  margin-top: 32rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
  text-align: center;
}

.step1-footer {
  flex-shrink: 0;
  padding: 48rpx 0 calc(48rpx + env(safe-area-inset-bottom));
  text-align: center;
}

.step1-buyer-link {
  font-size: 28rpx;
  color: #999999;
}
