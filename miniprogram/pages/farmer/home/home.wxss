@import "../farmer-common.wxss";

.home-info-card {
  position: relative;
  display: flex;
  align-items: center;
  margin: 16px;
  padding: 20px 180rpx 20px 20px;
  background: #4caf50;
  border-radius: 12px;
}

.home-avatar {
  flex-shrink: 0;
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: #ffffff;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.home-avatar-text {
  color: #4caf50;
  font-size: 24px;
  font-weight: 600;
  line-height: 1;
  text-align: center;
}

.home-info-right {
  flex: 1;
  margin-left: 16px;
  min-width: 0;
}

.home-merchant-name {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #ffffff;
}

.home-status-tag {
  display: inline-block;
  margin-top: 8px;
  padding: 2px 8px;
  font-size: 12px;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4px;
}

.home-sale-toggle-wrap {
  position: absolute;
  right: 24rpx;
  top: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transform: translateY(-50%);
}

.home-sale-label {
  width: 150rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.home-sale-toggle {
  position: relative;
  width: 150rpx;
  height: 64rpx;
  border-radius: 32rpx;
  transition: background-color 0.2s ease;
}

.home-sale-toggle--on {
  background: #7bc96f;
}

.home-sale-toggle--off {
  background: #e85d5d;
}

.home-sale-toggle-thumb {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  z-index: 2;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.18);
  transition: transform 0.2s ease;
}

.home-sale-toggle--on .home-sale-toggle-thumb {
  transform: translateX(86rpx);
}

.home-sale-toggle--off .home-sale-toggle-thumb {
  transform: translateX(0);
}

.home-menu {
  display: flex;
  gap: 12px;
  margin: 16px;
}

.home-menu-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100px;
  background: #ffffff;
  border-radius: 12px;
  min-width: 0;
}

.home-menu-item--messages {
  position: relative;
}

.home-menu-badge {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 12px;
  height: 12px;
  background: #e53935;
  border-radius: 50%;
}

.home-menu-emoji {
  font-size: 28px;
  line-height: 1.2;
}

.home-menu-text {
  margin-top: 8px;
  font-size: 14px;
  color: #333333;
}

.home-buyer-entry {
  flex-shrink: 0;
  padding: 20px 16px calc(28px + env(safe-area-inset-bottom));
  text-align: center;
}

.home-buyer-entry-text {
  font-size: 14px;
  color: #888888;
  text-decoration: underline;
}
