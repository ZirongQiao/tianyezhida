.register-page {
  min-height: 100vh;
  background: #f5f5f5;
  box-sizing: border-box;
}

.register-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 12px;
  background: #ffffff;
  box-sizing: content-box;
  flex-shrink: 0;
}

.register-nav-back {
  width: 44px;
  height: 44px;
  font-size: 22px;
  color: #333333;
  line-height: 44px;
}

.register-nav-title {
  flex: 1;
  font-size: 17px;
  font-weight: 600;
  color: #333333;
  text-align: center;
}

.register-nav-step {
  width: 44px;
  font-size: 14px;
  color: #999999;
  line-height: 44px;
  text-align: right;
}

.register-progress {
  display: flex;
  gap: 8rpx;
  padding: 0 32rpx 24rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.register-progress-seg {
  flex: 1;
  height: 6rpx;
  border-radius: 3rpx;
  background: #eeeeee;
}

.register-progress-seg.active {
  background: #4caf50;
}

.register-card {
  margin: 32rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.register-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  background: #ffffff;
  border: 1px solid #eeeeee;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.register-field {
  margin-bottom: 32rpx;
}

.register-field:last-child {
  margin-bottom: 0;
}

.register-label {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.register-btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 90%;
  height: 100rpx;
  margin: 0 auto;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  background: #4caf50;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.register-btn-primary::after {
  border: none;
}

.register-picker {
  display: flex;
  align-items: center;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  background: #ffffff;
  border: 1px solid #eeeeee;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.register-picker-placeholder {
  color: #999999;
}
