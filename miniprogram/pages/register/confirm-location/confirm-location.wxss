@import "../register-common.wxss";

.confirm-location-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.confirm-map-wrap {
  position: relative;
  flex: 1;
  min-height: 0;
  margin: 0 32rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.confirm-map {
  width: 100%;
  height: 100%;
}

.confirm-pin {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 10;
  width: 40rpx;
  height: 56rpx;
  margin-left: -20rpx;
  margin-top: -56rpx;
  pointer-events: none;
}

.confirm-pin-head {
  width: 40rpx;
  height: 40rpx;
  background: #4caf50;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.confirm-pin-tail {
  width: 4rpx;
  height: 16rpx;
  margin: 0 auto;
  background: #4caf50;
  border-radius: 2rpx;
}

.confirm-hint {
  display: block;
  padding: 24rpx 32rpx 8rpx;
  font-size: 26rpx;
  color: #666666;
  text-align: center;
}

.confirm-tip {
  display: block;
  padding: 0 32rpx 8rpx;
  font-size: 24rpx;
  color: #e65100;
  text-align: center;
}

.confirm-footer {
  padding: 16rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #f5f5f5;
}

.confirm-footer .register-btn-primary {
  width: 100%;
}
